{
  "rewrites": [
    {
      "source": "/__/auth/:path*",
      "destination": "https://blog-89011.firebaseapp.com/__/auth/:path*"
    },
    {
      "source": "/sitemap.xml",
      "destination": "https://blog-api-gules-phi.vercel.app/api/post/sitemap"
    },
    {
      "source": "/api/:path*",
      "destination": "https://blog-api-gules-phi.vercel.app/api/:path*"
    },
    {
      "source": "/post/:slug",
      "destination": "https://blog-api-gules-phi.vercel.app/post/:slug"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}